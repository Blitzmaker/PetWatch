generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum ActivityLevel {
  LOW
  MEDIUM
  HIGH
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum UserRole {
  USER
  MODERATOR
  CURATOR
  FOOD_REVIEWER
  ADMIN
}

enum FoodStatus {
  DRAFT_LOCAL
  PENDING_REVIEW
  APPROVED_PUBLIC
  REJECTED
}

enum RecipeVisibility {
  PRIVATE
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  isBlocked    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dogs           Dog[]
  foodsCreated   Food[]            @relation("FoodsCreatedBy")
  foodsReviewed  Food[]            @relation("FoodsReviewedBy")
  recipes        Recipe[]
  refreshTokens  RefreshToken[]
  cmsPosts       CmsPost[]
  threads        CommunityThread[]
  communityPosts CommunityPost[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Dog {
  id              String        @id @default(cuid())
  userId          String
  name            String
  breed           String?
  birthdate       DateTime?
  sex             Sex           @default(UNKNOWN)
  targetWeightKg  Float?
  activityLevel   ActivityLevel @default(MEDIUM)
  isNeutered      Boolean       @default(false)
  dailyKcalTarget Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weights    WeightEntry[]
  meals      Meal[]
  activities ActivityEntry[]

  @@index([userId])
}

model WeightEntry {
  id       String   @id @default(cuid())
  dogId    String
  date     DateTime
  weightKg Float

  createdAt DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@index([dogId, date])
}

model Activity {
  id            String          @id @default(cuid())
  name          String          @unique
  kcalPerMinute Float
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  entries ActivityEntry[]
}

model ActivityEntry {
  id                    String   @id @default(cuid())
  dogId                 String
  activityId            String
  durationMinutes       Int
  performedAt           DateTime
  kcalPerMinuteSnapshot Float
  kcalMultiplier        Float
  kcalBurned            Float
  createdAt             DateTime @default(now())

  dog      Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Restrict)

  @@index([dogId, performedAt])
  @@index([activityId])
}

model Food {
  id                String  @id @default(cuid())
  barcode           String  @unique
  name              String
  brand             String?
  kcalPer100g       Int
  proteinPercent    Float?
  fatPercent        Float?
  crudeAshPercent   Float?
  crudeFiberPercent Float?

  createdByUserId   String?
  status            FoodStatus @default(DRAFT_LOCAL)
  reviewedByAdminId String?
  reviewComment     String?
  approvedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  createdBy   User?       @relation("FoodsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedBy  User?       @relation("FoodsReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  mealEntries MealEntry[]
  recipeItems RecipeItem[]
}


model Recipe {
  id                String           @id @default(cuid())
  createdByUserId   String
  title             String
  description       String?
  visibility        RecipeVisibility @default(PRIVATE)
  defaultPortions   Float?
  yieldTotalGrams   Float
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  createdBy User         @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  items     RecipeItem[]
  steps     RecipeStep[]

  @@index([createdByUserId, createdAt])
}

model RecipeItem {
  id        String  @id @default(cuid())
  recipeId  String
  foodId    String
  grams     Float
  sortOrder Int

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Restrict)

  @@index([recipeId, sortOrder])
  @@index([foodId])
}

model RecipeStep {
  id          String  @id @default(cuid())
  recipeId    String
  sortOrder   Int
  title       String?
  instruction String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sortOrder])
}

model CmsCategory {
  id        String   @id @default(cuid())
  title     String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts CmsPost[]
}

model CmsPost {
  id          String            @id @default(cuid())
  title       String
  slug        String            @unique
  teaser      String?
  content     String
  status      PublicationStatus @default(DRAFT)
  publishedAt DateTime?
  authorId    String
  categoryId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  author   User         @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category CmsCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
}

model CommunityTopic {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  status      PublicationStatus @default(PUBLISHED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  threads CommunityThread[]
}

model CommunityThread {
  id        String            @id @default(cuid())
  topicId   String
  authorId  String
  title     String
  content   String
  status    PublicationStatus @default(PUBLISHED)
  isLocked  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  topic  CommunityTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author User            @relation(fields: [authorId], references: [id], onDelete: Restrict)
  posts  CommunityPost[]

  @@index([topicId, createdAt])
}

model CommunityPost {
  id        String            @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  status    PublicationStatus @default(PUBLISHED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  thread CommunityThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User            @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([threadId, createdAt])
}

model Meal {
  id      String   @id @default(cuid())
  dogId   String
  eatenAt DateTime
  note    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dog     Dog         @relation(fields: [dogId], references: [id], onDelete: Cascade)
  entries MealEntry[]

  @@index([dogId, eatenAt])
}

model MealEntry {
  id                        String   @id @default(cuid())
  mealId                    String
  foodId                    String
  grams                     Float
  mealType                  MealType @default(DINNER)
  sourceRecipeId            String?
  sourceRecipeTitleSnapshot String?

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Restrict)

  @@index([mealId])
  @@index([foodId])
  @@index([sourceRecipeId])
}
